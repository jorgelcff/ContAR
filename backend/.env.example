PORT=3001
MONGODB_URI=mongodb://localhost:27017/avaturn3d

# OBRIGATÓRIO em produção — use uma string longa e aleatória
AUTH_JWT_SECRET=change_me_in_production

# Email — reset de senha (Resend: https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=ContAR <noreply@seudominio.com>

# URL pública do frontend — usada nos links do email de reset
FRONTEND_URL=https://seudominio.com

# TTS com ElevenLabs (opcional — sem a chave o botão retorna 503)
ELEVENLABS_API_KEY=

# Avaturn SDK (opcional)
AVATURN_API_TOKEN=
AVATURN_API_BASE_URL=https://api.avaturn.me/api/v1

# CORS — domínio(s) do frontend em produção (separados por vírgula)
CORS_ORIGIN=http://localhost:5173

# Proxy (Render, Railway, etc.)
TRUST_PROXY=1
