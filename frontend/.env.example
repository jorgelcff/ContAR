# Direct Web SDK mode (no backend session creation):
# Use ONE of the options below.

# Option A: full URL
VITE_AVATURN_DIRECT_URL=https://jlcf.avaturn.dev

# Option B: subdomain only
VITE_AVATURN_SUBDOMAIN=jlcf

# Optional: fixed user id used by frontend to list avatars in direct mode
# VITE_AVATURN_USER_ID=

# Optional debug flag: when true, prevents fallback to backend /api/avatar/session
# VITE_AVATURN_DISABLE_BACKEND_FALLBACK=true
